{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash /absolute/path/to/claude_status_dashboard/hooks/claude-status-dashboard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
